---
const { activePage = 'home' } = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-[rgba(11,18,32,0.95)] border-b border-[#1a3a2a] flex items-center justify-between px-12 h-16">

  <!-- Logo on the LEFT -->
  <a href="/" class="flex items-center gap-3 no-underline">
    <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-[#10b981] to-[#059669] flex items-center justify-center text-sm font-bold text-white">
      AM
    </div>
    <span class="text-[15px] font-semibold text-white">
      Aleeza <span class="text-[#8b90a7] font-normal">/ Backend Dev</span>
    </span>
  </a>

  <!-- Nav Links on the RIGHT -->
  <div class="hidden md:flex items-center gap-1">
    <a href="/"
       class={`text-sm px-4 py-1.5 rounded-md transition-colors no-underline ${activePage === 'home' ? 'text-white bg-card2' : 'text-[#8b90a7] hover:text-white hover:bg-card'}`}>
      Home
    </a>
    <a href="/experience"
       class={`text-sm px-4 py-1.5 rounded-md transition-colors no-underline ${activePage === 'experience' ? 'text-white bg-card2' : 'text-[#8b90a7] hover:text-white hover:bg-card'}`}>
      Experience
    </a>
    <a href="/projects"
       class={`text-sm px-4 py-1.5 rounded-md transition-colors no-underline ${activePage === 'projects' ? 'text-white bg-card2' : 'text-[#8b90a7] hover:text-white hover:bg-card'}`}>
      Projects
    </a>
    <a href="/contact"
       class={`text-sm px-4 py-1.5 rounded-md transition-colors no-underline ${activePage === 'contact' ? 'text-white bg-card2' : 'text-[#8b90a7] hover:text-white hover:bg-card'}`}>
      Contact
    </a>

    <div class="ml-4 flex items-center gap-2 bg-[#0a2a1a] border border-[#10b981]/30 text-green text-[13px] font-medium px-4 py-1.5 rounded-full">
      <span class="w-2 h-2 rounded-full bg-green animate-pulse_green"></span>
      Available
    </div>
  </div>

</nav>