---
---

<div class="shutter-wrapper" id="shutterWrapper">

  <!-- Code content behind shutter -->
  <div class="shutter-content">
    <div class="flex items-center gap-2 px-4 py-3 border-b border-[#1a3a2a] bg-[#080c18]">
      <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
      <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
      <span class="w-3 h-3 rounded-full bg-[#28ca41]"></span>
      <span class="ml-2 text-[#4a6070] text-xs font-mono">Developer.java</span>
    </div>
    <div class="px-6 py-5 leading-[1.8] font-mono text-[13.5px]">
      <div class="text-[#3a5060]">// — Backend Developer Profile</div>
      <div>&nbsp;</div>
      <div><span class="text-[#10b981]">public class</span><span class="text-white font-semibold"> Developer </span><span class="text-[#8b8fa8]">{"{"}</span></div>
      <div>&nbsp;</div>
      <div class="pl-6"><span class="text-[#3b82f6]">String</span>&nbsp;&nbsp; <span class="text-[#34d399]">name</span>   = <span class="text-amber-400">"Aleeza Memon"</span> ;</div>
      <div class="pl-6"><span class="text-[#3b82f6]">String</span>&nbsp;&nbsp; <span class="text-[#34d399]">role</span>   = <span class="text-amber-400">"Backend Developer"</span> ;</div>
      <div class="pl-6"><span class="text-[#3b82f6]">String</span>&nbsp;&nbsp; <span class="text-[#34d399]">status</span> = <span class="text-amber-400">"Available"</span> ;</div>
      <div class="pl-6"><span class="text-[#3b82f6]">String</span>&nbsp;&nbsp; <span class="text-[#34d399]">uni</span>    = <span class="text-amber-400">"Mehran UET"</span> ;</div>
      <div>&nbsp;</div>
      <div class="pl-6"><span class="text-[#3b82f6]">String[]</span> <span class="text-[#34d399]">stack</span> = <span class="text-[#8b8fa8]">{"{"}</span></div>
      <div class="pl-11"><span class="text-amber-400">"Spring Boot"</span> , <span class="text-amber-400">"JWT Auth"</span> ,</div>
      <div class="pl-11"><span class="text-amber-400">"REST APIs"</span> ,&nbsp; <span class="text-amber-400">"MySQL"</span> ,</div>
      <div class="pl-11"><span class="text-amber-400">"Spring Security"</span></div>
      <div class="pl-6"><span class="text-[#8b8fa8]">{"} ;"}</span></div>
      <div>&nbsp;</div>
      <div><span class="text-[#8b8fa8]">{"}"}</span></div>
    </div>
    <div class="flex items-center gap-2 px-6 py-3 border-t border-[#1a3a2a] bg-[#060a14]">
      <span class="text-[#3a5060]">$</span>
      <span class="text-[#10b981]">./run-api</span>
      <span class="text-[#34d399]">&nbsp;--port</span>
      <span class="text-white"> = 8080</span>
      <span class="cursor-blink align-middle ml-1"></span>
    </div>
  </div>

  <!-- Shutter panel -->
  <div class="shutter-panel" id="shutterPanel">
    <div class="shutter-lines">
      {Array.from({length: 14}).map(() => (
        <div class="shutter-line"></div>
      ))}
    </div>
    <div class="shutter-center">
      <div class="lock-icon" id="lockIcon">
        <svg width="32" height="38" viewBox="0 0 32 38" fill="none">
          <rect x="4" y="16" width="24" height="20" rx="4" fill="#1a3a2a" stroke="#10b981" stroke-width="2"/>
          <path id="lockArc" d="M9 16V11a7 7 0 0 1 14 0v5" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <circle cx="16" cy="26" r="3" fill="#10b981"/>
          <rect x="14.5" y="26" width="3" height="5" rx="1.5" fill="#10b981"/>
        </svg>
      </div>
      <div class="shutter-label">loading profile...</div>
    </div>
  </div>

  <!-- Bunny on RIGHT side -->
  <div class="bunny-scene" id="bunnyScene">

    <!-- Speech bubble -->
    <div class="speech-bubble" id="speechBubble">✨ ta-da!</div>

    <!-- SVG Realistic Bunny -->
    <svg id="bunnySvg" class="bunny-svg" viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg">

      <!-- TAIL -->
      <ellipse cx="28" cy="118" rx="10" ry="9"
        fill="white" stroke="#e0cfc0" stroke-width="1.5"
        filter="url(#fluff)"/>

      <!-- BODY -->
      <ellipse cx="62" cy="115" rx="32" ry="36"
        fill="#f0e6d8" stroke="#d4c4b0" stroke-width="1.5"/>

      <!-- BELLY -->
      <ellipse cx="63" cy="120" rx="18" ry="22"
        fill="#faf3ec" stroke="none" opacity="0.9"/>

      <!-- BACK LEG LEFT -->
      <ellipse cx="38" cy="143" rx="14" ry="9"
        fill="#e8d8c8" stroke="#d4c4b0" stroke-width="1.2"
        transform="rotate(-15 38 143)"/>

      <!-- BACK LEG RIGHT -->
      <ellipse cx="86" cy="143" rx="14" ry="9"
        fill="#e8d8c8" stroke="#d4c4b0" stroke-width="1.2"
        transform="rotate(15 86 143)"/>

      <!-- ARM LEFT (raised when pushing) -->
      <g id="armLeftGroup" style="transform-origin: 38px 98px; transform: rotate(20deg);">
        <ellipse cx="34" cy="108" rx="9" ry="16"
          fill="#e8d8c8" stroke="#d4c4b0" stroke-width="1.2"
          transform="rotate(20 34 108)"/>
        <!-- paw -->
        <ellipse cx="28" cy="120" rx="7" ry="5"
          fill="#e8d8c8" stroke="#d4c4b0" stroke-width="1"/>
        <circle cx="25" cy="118" r="2" fill="#d4c4b0"/>
        <circle cx="28" cy="116" r="2" fill="#d4c4b0"/>
        <circle cx="31" cy="118" r="2" fill="#d4c4b0"/>
      </g>

      <!-- ARM RIGHT (raised when pushing) -->
      <g id="armRightGroup" style="transform-origin: 86px 98px; transform: rotate(-20deg);">
        <ellipse cx="88" cy="108" rx="9" ry="16"
          fill="#e8d8c8" stroke="#d4c4b0" stroke-width="1.2"
          transform="rotate(-20 88 108)"/>
        <!-- paw -->
        <ellipse cx="94" cy="120" rx="7" ry="5"
          fill="#e8d8c8" stroke="#d4c4b0" stroke-width="1"/>
        <circle cx="91" cy="118" r="2" fill="#d4c4b0"/>
        <circle cx="94" cy="116" r="2" fill="#d4c4b0"/>
        <circle cx="97" cy="118" r="2" fill="#d4c4b0"/>
      </g>

      <!-- NECK -->
      <ellipse cx="62" cy="83" rx="16" ry="10"
        fill="#f0e6d8" stroke="none"/>

      <!-- HEAD -->
      <ellipse cx="62" cy="62" rx="28" ry="26"
        fill="#f0e6d8" stroke="#d4c4b0" stroke-width="1.5"/>

      <!-- HEAD SHADING -->
      <ellipse cx="62" cy="58" rx="22" ry="18"
        fill="#f5ede2" stroke="none" opacity="0.5"/>

      <!-- EAR LEFT -->
      <g id="earLeftGroup" style="transform-origin: 50px 42px;">
        <ellipse cx="48" cy="22" rx="11" ry="26"
          fill="#f0e6d8" stroke="#d4c4b0" stroke-width="1.5"
          transform="rotate(-8 48 22)"/>
        <ellipse cx="48" cy="22" rx="6" ry="20"
          fill="#f0b0c0" stroke="none" opacity="0.7"
          transform="rotate(-8 48 22)"/>
        <!-- ear fur lines -->
        <line x1="46" y1="8" x2="46" y2="38" stroke="#d4c4b0" stroke-width="0.5" opacity="0.4"
          transform="rotate(-8 48 22)"/>
      </g>

      <!-- EAR RIGHT -->
      <g id="earRightGroup" style="transform-origin: 76px 42px;">
        <ellipse cx="76" cy="22" rx="11" ry="26"
          fill="#f0e6d8" stroke="#d4c4b0" stroke-width="1.5"
          transform="rotate(8 76 22)"/>
        <ellipse cx="76" cy="22" rx="6" ry="20"
          fill="#f0b0c0" stroke="none" opacity="0.7"
          transform="rotate(8 76 22)"/>
        <line x1="76" y1="8" x2="76" y2="38" stroke="#d4c4b0" stroke-width="0.5" opacity="0.4"
          transform="rotate(8 76 22)"/>
      </g>

      <!-- FUR TEXTURE on head -->
      <path d="M40 52 Q42 46 46 50" stroke="#d4c4b0" stroke-width="0.8" fill="none" opacity="0.5"/>
      <path d="M76 50 Q80 46 82 52" stroke="#d4c4b0" stroke-width="0.8" fill="none" opacity="0.5"/>
      <path d="M58 40 Q62 35 66 40" stroke="#d4c4b0" stroke-width="0.8" fill="none" opacity="0.4"/>

      <!-- EYES -->
      <g id="eyeLeftGroup">
        <!-- eye white -->
        <ellipse cx="50" cy="60" rx="8" ry="9" fill="white" stroke="#c8b8a8" stroke-width="0.8"/>
        <!-- iris -->
        <ellipse cx="51" cy="61" rx="5.5" ry="6" fill="#8b6a4a"/>
        <!-- pupil -->
        <ellipse cx="51" cy="62" rx="3.5" ry="4" fill="#2d1a0e"/>
        <!-- shine -->
        <circle cx="53" cy="59" r="1.5" fill="white" opacity="0.9"/>
        <circle cx="49" cy="63" r="0.8" fill="white" opacity="0.5"/>
        <!-- eyelid top -->
        <path d="M42 58 Q50 52 58 58" stroke="#c8a898" stroke-width="1.2" fill="none"/>
        <!-- lashes -->
        <line x1="44" y1="57" x2="42" y2="54" stroke="#c8a898" stroke-width="0.8"/>
        <line x1="48" y1="54" x2="47" y2="51" stroke="#c8a898" stroke-width="0.8"/>
        <line x1="53" y1="54" x2="53" y2="51" stroke="#c8a898" stroke-width="0.8"/>
        <line x1="57" y1="56" x2="59" y2="53" stroke="#c8a898" stroke-width="0.8"/>
      </g>

      <g id="eyeRightGroup">
        <ellipse cx="74" cy="60" rx="8" ry="9" fill="white" stroke="#c8b8a8" stroke-width="0.8"/>
        <ellipse cx="75" cy="61" rx="5.5" ry="6" fill="#8b6a4a"/>
        <ellipse cx="75" cy="62" rx="3.5" ry="4" fill="#2d1a0e"/>
        <circle cx="77" cy="59" r="1.5" fill="white" opacity="0.9"/>
        <circle cx="73" cy="63" r="0.8" fill="white" opacity="0.5"/>
        <path d="M66 58 Q74 52 82 58" stroke="#c8a898" stroke-width="1.2" fill="none"/>
        <line x1="68" y1="57" x2="66" y2="54" stroke="#c8a898" stroke-width="0.8"/>
        <line x1="72" y1="54" x2="71" y2="51" stroke="#c8a898" stroke-width="0.8"/>
        <line x1="77" y1="54" x2="77" y2="51" stroke="#c8a898" stroke-width="0.8"/>
        <line x1="81" y1="56" x2="83" y2="53" stroke="#c8a898" stroke-width="0.8"/>
      </g>

      <!-- HAPPY EYES (hidden initially) -->
      <g id="happyEyes" style="display:none;">
        <path d="M42 61 Q50 54 58 61" stroke="#2d1a0e" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <path d="M66 61 Q74 54 82 61" stroke="#2d1a0e" stroke-width="2.5" fill="none" stroke-linecap="round"/>
      </g>

      <!-- NOSE -->
      <ellipse cx="62" cy="72" rx="5" ry="3.5"
        fill="#f0a0b0" stroke="#e08898" stroke-width="0.8"/>
      <!-- nose highlight -->
      <ellipse cx="61" cy="71" rx="2" ry="1.2" fill="white" opacity="0.4"/>

      <!-- WHISKERS LEFT -->
      <line x1="30" y1="72" x2="54" y2="74" stroke="#c8b8a8" stroke-width="0.8" opacity="0.7"/>
      <line x1="30" y1="76" x2="54" y2="76" stroke="#c8b8a8" stroke-width="0.8" opacity="0.7"/>
      <line x1="32" y1="80" x2="54" y2="78" stroke="#c8b8a8" stroke-width="0.8" opacity="0.7"/>

      <!-- WHISKERS RIGHT -->
      <line x1="94" y1="72" x2="70" y2="74" stroke="#c8b8a8" stroke-width="0.8" opacity="0.7"/>
      <line x1="94" y1="76" x2="70" y2="76" stroke="#c8b8a8" stroke-width="0.8" opacity="0.7"/>
      <line x1="92" y1="80" x2="70" y2="78" stroke="#c8b8a8" stroke-width="0.8" opacity="0.7"/>

      <!-- MOUTH -->
      <path d="M62 75 Q58 80 55 78" stroke="#c07080" stroke-width="1.2" fill="none" stroke-linecap="round"/>
      <path d="M62 75 Q66 80 69 78" stroke="#c07080" stroke-width="1.2" fill="none" stroke-linecap="round"/>

      <!-- BLUSH -->
      <ellipse cx="42" cy="70" rx="8" ry="5" fill="#f0a0b0" opacity="0.25"/>
      <ellipse cx="82" cy="70" rx="8" ry="5" fill="#f0a0b0" opacity="0.25"/>

      <!-- FUR on body -->
      <path d="M48 88 Q50 83 54 87" stroke="#d4c4b0" stroke-width="0.8" fill="none" opacity="0.5"/>
      <path d="M62 84 Q64 79 68 83" stroke="#d4c4b0" stroke-width="0.8" fill="none" opacity="0.5"/>
      <path d="M72 90 Q75 85 78 89" stroke="#d4c4b0" stroke-width="0.8" fill="none" opacity="0.5"/>

      <!-- Filters -->
      <defs>
        <filter id="fluff">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" result="noise"/>
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="3" xChannelSelector="R" yChannelSelector="G"/>
        </filter>
      </defs>

    </svg>
  </div>

</div>

<style>
/* ── WRAPPER ── */
.shutter-wrapper {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  background: #0a0f1e;
  border: 1px solid #1a3a2a;
  box-shadow: 0 8px 32px rgba(16,185,129,0.15);
}

.shutter-wrapper.floating {
  animation: float 5s ease-in-out infinite;
}

@keyframes float {
  0%,100% { transform: translateY(0px); box-shadow: 0 8px 32px rgba(16,185,129,0.15); }
  50%     { transform: translateY(-14px); box-shadow: 0 22px 48px rgba(16,185,129,0.28); }
}

/* ── CURSOR ── */
.cursor-blink {
  display: inline-block;
  width: 2px; height: 14px;
  background: #10b981;
  vertical-align: middle;
  animation: blink 1s infinite;
}
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }

/* ── SHUTTER ── */
.shutter-panel {
  position: absolute;
  inset: 0;
  z-index: 10;
  background: linear-gradient(170deg, #0c1828 0%, #081420 50%, #0b1f1a 100%);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: translateY(0%);
  transition: transform 1.1s cubic-bezier(0.4, 0, 0.2, 1);
}

.shutter-panel.open {
  transform: translateY(-105%);
}

.shutter-lines {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  padding: 10px 20px;
  pointer-events: none;
}

.shutter-line {
  height: 1.5px;
  background: linear-gradient(90deg, transparent, rgba(16,185,129,0.2), transparent);
  border-radius: 2px;
}

.shutter-center {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

.lock-icon {
  transition: transform 0.4s, opacity 0.4s;
}
.lock-icon.unlocked {
  transform: translateY(-4px) rotate(15deg);
  opacity: 0.4;
}

#lockArc {
  transition: d 0.4s;
}

.shutter-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #10b981;
  opacity: 0.6;
  letter-spacing: 1px;
}

/* ── BUNNY SCENE — positioned RIGHT side ── */
.bunny-scene {
  position: absolute;
  bottom: -180px;
  right: 16px;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: bottom 0.8s cubic-bezier(0.34, 1.3, 0.64, 1);
  width: 120px;
}

.bunny-scene.rise {
  bottom: -30px;
}

.bunny-scene.sink {
  bottom: -160px;
  transition: bottom 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ── SPEECH BUBBLE ── */
.speech-bubble {
  background: #0d1e14;
  border: 1px solid #10b981;
  border-radius: 10px;
  padding: 4px 10px;
  font-size: 11px;
  color: #34d399;
  font-family: 'JetBrains Mono', monospace;
  white-space: nowrap;
  margin-bottom: 6px;
  opacity: 0;
  transform: scale(0.6) translateY(6px);
  transition: opacity 0.35s, transform 0.35s;
  position: relative;
}
.speech-bubble::after {
  content: '';
  position: absolute;
  bottom: -7px; left: 50%;
  transform: translateX(-50%);
  border: 6px solid transparent;
  border-top-color: #10b981;
  border-bottom: none;
}
.speech-bubble.show {
  opacity: 1;
  transform: scale(1) translateY(0);
}

/* ── BUNNY SVG ── */
.bunny-svg {
  width: 110px;
  height: auto;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
}

/* ARM ANIMATIONS */
@keyframes armsUp {
  to { transform: rotate(-75deg) translate(-4px, -12px); }
}
@keyframes armsUpRight {
  to { transform: rotate(75deg) translate(4px, -12px); }
}
@keyframes armsDown {
  to { transform: rotate(20deg); }
}
@keyframes armsDownRight {
  to { transform: rotate(-20deg); }
}

#armLeftGroup.pushing {
  animation: armsUp 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards;
}
#armRightGroup.pushing {
  animation: armsUpRight 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards;
}
#armLeftGroup.relaxed {
  animation: armsDown 0.5s ease forwards;
}
#armRightGroup.relaxed {
  animation: armsDownRight 0.5s ease forwards;
}

/* EAR BOUNCE */
@keyframes earBounceL {
  0%,100% { transform: rotate(-8deg); }
  40%     { transform: rotate(-18deg) scaleY(1.08); }
  70%     { transform: rotate(-4deg); }
}
@keyframes earBounceR {
  0%,100% { transform: rotate(8deg); }
  40%     { transform: rotate(18deg) scaleY(1.08); }
  70%     { transform: rotate(4deg); }
}
#earLeftGroup.bounce  { animation: earBounceL 0.5s ease 3; }
#earRightGroup.bounce { animation: earBounceR 0.5s ease 3; }

/* BUNNY WIGGLE */
@keyframes bunnyWiggle {
  0%,100% { transform: rotate(0deg); }
  25%     { transform: rotate(-4deg); }
  75%     { transform: rotate(4deg); }
}
#bunnySvg.wiggle {
  animation: bunnyWiggle 0.35s ease 3;
}
</style>

<script>
function runBunnyAnimation() {
  const wrapper      = document.getElementById('shutterWrapper');
  const shutter      = document.getElementById('shutterPanel');
  const lock         = document.getElementById('lockIcon');
  const scene        = document.getElementById('bunnyScene');
  const armL         = document.getElementById('armLeftGroup');
  const armR         = document.getElementById('armRightGroup');
  const earL         = document.getElementById('earLeftGroup');
  const earR         = document.getElementById('earRightGroup');
  const bunnySvg     = document.getElementById('bunnySvg');
  const bubble       = document.getElementById('speechBubble');
  const happyEyes    = document.getElementById('happyEyes');
  const normalEyeL   = document.getElementById('eyeLeftGroup');
  const normalEyeR   = document.getElementById('eyeRightGroup');

  if (!wrapper) return;

  // 1 — bunny rises (0.5s)
  setTimeout(() => {
    scene?.classList.add('rise');
  }, 500);

  // 2 — arms go up + lock unlocks (1.3s)
  setTimeout(() => {
    armL?.classList.add('pushing');
    armR?.classList.add('pushing');
    lock?.classList.add('unlocked');
  }, 1300);

  // 3 — shutter slides UP (1.8s)
  setTimeout(() => {
    shutter?.classList.add('open');
  }, 1800);

  // 4 — happy eyes + ears bounce + wiggle + bubble (2.7s)
  setTimeout(() => {
    if (normalEyeL) normalEyeL.style.display = 'none';
    if (normalEyeR) normalEyeR.style.display = 'none';
    if (happyEyes)  happyEyes.style.display = 'block';
    earL?.classList.add('bounce');
    earR?.classList.add('bounce');
    bunnySvg?.classList.add('wiggle');
    bubble?.classList.add('show');
  }, 2700);

  // 5 — arms relax (3.2s)
  setTimeout(() => {
    armL?.classList.remove('pushing'); armL?.classList.add('relaxed');
    armR?.classList.remove('pushing'); armR?.classList.add('relaxed');
  }, 3200);

  // 6 — bubble hides (3.7s)
  setTimeout(() => {
    bubble?.classList.remove('show');
  }, 3700);

  // 7 — bunny sinks back down (4.2s)
  setTimeout(() => {
    scene?.classList.add('sink');
  }, 4200);

  // 8 — wrapper floats (5s)
  setTimeout(() => {
    wrapper?.classList.add('floating');
  }, 5000);
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', runBunnyAnimation);
} else {
  runBunnyAnimation();
}
</script>