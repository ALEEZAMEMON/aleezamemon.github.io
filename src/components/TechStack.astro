---
const chips = [
  { label: 'Java',            color: '#f59e0b' },
  { label: 'Spring Boot',     color: '#22c55e' },
  { label: 'Spring Security', color: '#22c55e' },
  { label: 'REST APIs',       color: '#7c6cf0' },
  { label: 'JWT Auth',        color: '#7c6cf0' },
  { label: 'MySQL',           color: '#22d3ee' },
  { label: 'Oracle DB',       color: '#f59e0b' },
  { label: 'Git & GitHub',    color: '#f87171' },
  { label: 'Postman',         color: '#fb923c' },
  
];
---
<section class="max-w-[1200px] mx-auto px-12 py-20">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div>
      <div class="text-xs font-bold tracking-[2px] text-purple uppercase mb-4">TECH STACK</div>
      <h2 class="text-[clamp(36px,4vw,52px)] font-black tracking-[-1.5px] leading-[1.1] mb-3">
        Technologies<br/>I Work With
      </h2>
      <p class="text-[#8b90a7] text-[15px] mb-8">Backend-focused. Production-tested. Always learning.</p>
      <a href="#projects" class="inline-flex items-center gap-2 text-[#8b90a7] text-sm font-medium border border-border px-5 py-2.5 rounded-lg hover:text-white hover:border-[#3a3f5a] transition-colors">
        See What I Build →
      </a>
    </div>
    <div class="flex flex-wrap gap-2.5">
      {chips.map(c => (
        <div class="inline-flex items-center gap-2 bg-card border border-border text-[#8b90a7] text-[13px] font-medium px-4 py-2 rounded-lg">
          <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background:${c.color}`}></span>
          {c.label}
        </div>
      ))}
    </div>
  </div>
</section>