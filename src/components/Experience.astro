---
const jobs = [
  {
    title: 'Java Spring Boot Backend Developer',
    company: 'Self-Employed · Java · Spring Boot',
    date: 'Aug 2024 — Present',
    location: 'Sindh, Pakistan',
    points: [
      'Develop and maintain scalable backend applications using Java and Spring Boot for enterprise-level systems.',
      'Design and build secure REST APIs with authentication and authorization using JWT, Auth0, and Spring Security.',
      'Work with relational databases such as MySQL and Oracle for data storage, optimization, and query management.',
      'Use GitHub for version control, collaboration, code reviews, and CI/CD workflow integration.',
      'Implement backend features including API integration, database connectivity, exception handling, logging, and performance optimization.',
    ],
    tags: ['Java','JWT','Spring Security','Auth0','REST APIs','MySQL','Oracle','Git','GitHub'],
  },
  {
    title: 'Hackathon Participant',
    company: 'CCTRS — Carbon Contribution Tracking & Reward System',
    date: '2026',
    location: 'Sindh, Pakistan',
    points: [
      'Participated in a hackathon presenting CCTRS, focused on promoting environmentally responsible activities through digital tracking and rewards.',
      'Designed backend modules for user activity tracking, reward point management, and carbon contribution calculations using Spring Boot and Java.',
      'Developed secure REST APIs for user authentication, activity submission, and reward distribution with MySQL integration.',
      'Collaborated with team members using GitHub for version control, feature management, and project coordination.',
      'Contributed to system planning, backend architecture, and problem-solving to build a scalable sustainability platform.',
    ],
    tags: ['CCTRS','Spring Boot','React','Vercel','MySQL','GitHub'],
  },
  {
    title: 'Software Engineering Student',
    company: 'Mehran University of Engineering & Technology',
    date: '2024 — Present',
    location: 'Sindh, Pakistan',
    points: [
      'Pursuing a degree in Software Engineering with a focus on software development, problem solving, and modern computing technologies.',
      'Object-Oriented Programming (OOP) — inheritance, polymorphism, abstraction, and encapsulation.',
      'Data Structures and Algorithms (DSA) — efficient problem solving, optimization, and logical thinking.',
      'Computer Networking — network architecture, protocols, cloud computing basics, and communication systems.',
      'Worked on software engineering practicals — system design, database management, teamwork, documentation, and application development.',
    ],
    tags: ['Java','OOP','DSA','SQL','Git','SE','SRE'],
  },
];
---

<div id="experience" class="bg-secondary border-t border-b border-border">
  <section class="max-w-[1200px] mx-auto px-12 py-20">

    <!-- Section Label -->
    <div class="text-xs font-bold tracking-[2px] text-[#10b981] uppercase mb-4">
      EXPERIENCE
    </div>

    <!-- Heading -->
    <div class="title-scan-wrapper">

      <h2 class="experience-title text-[clamp(36px,4vw,52px)] font-black tracking-[-1.5px] leading-[1.1] text-white relative inline-block">
        What I've Done
        <span class="scan-line" id="scanLine"></span>
      </h2>

      <!-- Bigger SVG Magnifier -->
      <span class="magnifier" id="magnifier">

        <svg width="78"
             height="78"
             viewBox="0 0 78 78"
             fill="none"
             xmlns="http://www.w3.org/2000/svg">

          <defs>
            <linearGradient id="mgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#10b981"/>
              <stop offset="100%" stop-color="#3b82f6"/>
            </linearGradient>
          </defs>

          <!-- Glass -->
          <circle
            cx="30"
            cy="30"
            r="20"
            stroke="url(#mgGrad)"
            stroke-width="5"
            fill="rgba(16,185,129,0.08)"
          />

          <!-- Handle -->
          <line
            x1="44"
            y1="44"
            x2="66"
            y2="66"
            stroke="url(#mgGrad)"
            stroke-width="6"
            stroke-linecap="round"
          />
        </svg>

      </span>
    </div>

    <p class="text-[#8b90a7] text-[15px] mb-12">
      My journey through work, hackathons, and academics.
    </p>

    <!-- Timeline -->
    <div class="relative flex flex-col gap-8 pl-7">

      <div
        class="absolute left-[10px] top-0 bottom-0 w-0.5 rounded-full"
        style="background: linear-gradient(to bottom, #10b981, rgba(16,185,129,0.08));"
      ></div>

      {jobs.map(job => (
        <div class="relative flex gap-7 items-start">

          <!-- Timeline Dot -->
          <div
            class="absolute -left-[34px] top-6 w-3.5 h-3.5 rounded-full z-10"
            style="
              background:#10b981;
              border:3px solid var(--color-secondary);
              box-shadow:0 0 0 3px rgba(16,185,129,0.3);
            "
          ></div>

          <!-- Card -->
          <div
            class="flex-1 rounded-2xl p-8 transition-all duration-300"
            style="
              background:#121c30;
              border:1px solid rgba(26,58,42,0.9);
            "
            onmouseover="this.style.borderColor='rgba(16,185,129,0.45)'; this.style.boxShadow='0 4px 32px rgba(16,185,129,0.10)'"
            onmouseout="this.style.borderColor='rgba(26,58,42,0.9)'; this.style.boxShadow='none'"
          >

            <!-- Header -->
            <div class="flex justify-between items-start gap-4 flex-wrap mb-5">

              <div>
                <div class="text-[18px] font-extrabold text-white tracking-[-0.3px] mb-1">
                  {job.title}
                </div>

                <div class="text-[14px] font-semibold text-[#34d399]">
                  {job.company}
                </div>
              </div>

              <div class="text-right">

                <div class="inline-block bg-[rgba(16,185,129,0.12)] border border-[rgba(16,185,129,0.35)] text-[#34d399] text-xs font-semibold px-3 py-1 rounded-full mb-1">
                  {job.date}
                </div>

                <div class="text-xs text-[#5a5f7a] text-right">
                  {job.location}
                </div>

              </div>

            </div>

            <!-- Points -->
            <ul class="flex flex-col gap-2.5 mb-5">

              {job.points.map(pt => (
                <li class="relative pl-5 text-[14px] text-[#8b90a7] leading-[1.65]">

                  <span class="absolute left-0 top-0 text-[#10b981] font-bold text-[13px]">
                    ✓
                  </span>

                  {pt}
                </li>
              ))}

            </ul>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">

              {job.tags.map(tag => (
                <span
                  class="text-xs font-semibold px-3 py-1 rounded-full transition-colors cursor-default"
                  style="
                    border:1px solid rgba(16,185,129,0.35);
                    color:#34d399;
                  "
                  onmouseover="this.style.background='rgba(16,185,129,0.10)'; this.style.borderColor='#10b981'"
                  onmouseout="this.style.background='transparent'; this.style.borderColor='rgba(16,185,129,0.35)'"
                >
                  {tag}
                </span>
              ))}

            </div>

          </div>
        </div>
      ))}

    </div>
  </section>
</div>

<style>
  .title-scan-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
    overflow: visible;
    margin-bottom: 12px;
  }

  .experience-title {
    position: relative;
  }

  /* Animated underline */
  .scan-line {
    position: absolute;
    bottom: -5px;
    left: 0;

    width: 0%;
    height: 3px;

    background: linear-gradient(
      90deg,
      #10b981,
      #3b82f6
    );

    border-radius: 999px;

    box-shadow:
      0 0 12px rgba(16,185,129,0.7),
      0 0 22px rgba(59,130,246,0.35);

    transition:
      width 1.9s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .scan-line.go {
    width: 100%;
  }

  /* Bigger SVG magnifier */
  .magnifier {
    position: absolute;
    top: 50%;
    left: -90px;

    transform: translateY(-55%);

    opacity: 0;
    z-index: 5;

    pointer-events: none;

    filter:
      drop-shadow(0 0 10px rgba(16,185,129,0.7))
      drop-shadow(0 0 20px rgba(59,130,246,0.45));

    transition:
      left 1.9s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s ease;
  }

  .magnifier.go {
    opacity: 1;
    left: calc(100% + 12px);
  }

  .magnifier.fade {
    opacity: 0;
    transition: opacity 0.5s ease;
  }
</style>

<script>
  function runMagnifier() {

    const scanLine  = document.getElementById('scanLine');
    const magnifier = document.getElementById('magnifier');

    if (!scanLine || !magnifier) return;

    setTimeout(() => {
      scanLine.classList.add('go');
      magnifier.classList.add('go');
    }, 400);

    setTimeout(() => {
      magnifier.classList.add('fade');
    }, 2500);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runMagnifier);
  } else {
    runMagnifier();
  }
</script>